generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Turtle {
  id        String   @id
  name      String
  location  String
  habitat   String
  riskLevel String
  status    String
  createdAt DateTime @default(now())
}
model User {
  id        String   @id @default(cuid())
  fullName  String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}